# Odoo to PostgreSQL Synchronization Platform
# Copy this file to .env and configure your settings

# =============================================================================
# ODOO CONNECTION
# =============================================================================
ODOO_URL=http://localhost:8069
ODOO_DB=your_database
ODOO_USERNAME=admin

# Authentication (API Key is RECOMMENDED for security)
# Option 1: API Key Authentication (PREFERRED)
ODOO_API_KEY=your_api_key_here

# Option 2: Password Authentication (DEPRECATED - only use as fallback)
# ODOO_PASSWORD=your_password_here

# Odoo API Version (default: 17)
ODOO_API_VERSION=17

# =============================================================================
# POSTGRESQL CONNECTION
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sync_database
POSTGRES_USER=sync_user
POSTGRES_PASSWORD=your_secure_password

# =============================================================================
# SYNC CONFIGURATION
# =============================================================================
# Records per batch (default: 1000)
SYNC_BATCH_SIZE=1000

# Sync mode: "incremental" or "full"
SYNC_MODE=incremental

# Schedule interval in minutes (for scheduler mode)
SCHEDULE_INTERVAL_MINUTES=15

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# READ-ONLY MODE (SECURITY SETTING)
# This platform ALWAYS operates in READ-ONLY mode.
# Odoo is NEVER modified - data flows: Odoo → PostgreSQL only.
# DO NOT change this setting.
READ_ONLY_MODE=true

# CRITICAL WARNING - DO NOT SET THIS IN PRODUCTION
# Only for development/testing when absolutely necessary.
# This allows write operations to Odoo which is normally forbidden.
# ALLOW_UNSAFE_ODOO_WRITES=false

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=sync.log