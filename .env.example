# Odoo Connection
ODOO_URL=http://localhost:8069
ODOO_DB=odoo_db
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
ODOO_API_VERSION=17  # Odoo version (16, 17, etc.)

# PostgreSQL Connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sync_db
POSTGRES_USER=sync_user
POSTGRES_PASSWORD=your_secure_password

# Sync Configuration
SYNC_BATCH_SIZE=1000  # Records per batch
SYNC_MODE=incremental  # Options: full, incremental
SCHEDULE_INTERVAL_MINUTES=15  # For scheduled execution

# Logging
LOG_LEVEL=INFO
LOG_FILE=sync.log

# Optional: API Key for future FastAPI integration
# API_KEY=your_api_key_here
# API_HOST=0.0.0.0
# API_PORT=8000